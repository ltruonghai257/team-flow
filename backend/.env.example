DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/taskmanager
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LiteLLM - set the provider you want to use
# OpenAI
OPENAI_API_KEY=sk-...
# Anthropic
ANTHROPIC_API_KEY=...
# Default model (e.g. gpt-4o, claude-3-5-sonnet, ollama/llama3)
AI_MODEL=gpt-4o
